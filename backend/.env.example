APP_NAME="SST ROKA"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Base de datos principal
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=sst_roka
DB_USERNAME=sst_user
DB_PASSWORD=sst_secret
DB_ROOT_PASSWORD=root_secret

# Cache y sesiones
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=480

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail (configurar para notificaciones)
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@sstroka.pe"
MAIL_FROM_NAME="${APP_NAME}"

# Pusher / WebSocket (para tiempo real)
BROADCAST_DRIVER=pusher
PUSHER_APP_ID=sst_roka_app
PUSHER_APP_KEY=sst_roka_key
PUSHER_APP_SECRET=sst_roka_secret
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# Laravel Sanctum (JWT alternativo)
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost

# SMS (Twilio - para notificaciones)
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# 2FA
TOTP_DIGITS=6
TOTP_PERIOD=30

# Encriptación AES-256 para datos sensibles (EMO, médicos)
ENCRYPTION_KEY=

# Backups automáticos
BACKUP_DISK=local
BACKUP_PATH=backups

# SUNAFIL / MINTRA (integración futura)
MINTRA_API_URL=
MINTRA_API_KEY=

# Timezone Perú
APP_TIMEZONE=America/Lima
